---
type Props = {
  caption: string;
  imageSrc: string;
  imageAlt: string;
};
const { caption, imageSrc, imageAlt } = Astro.props;
---
<section class="screen-card">
  <figure>
    <img src={imageSrc} alt={imageAlt} />
    <figcaption>{caption}</figcaption>
  </figure>
</section>

<style>
  .screen-card {
    max-width: 520px;
    margin: 0 auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  figure { margin: 0; }
  img {
    width: 100%;
    height: 360px;
    object-fit: cover;
    background: var(--color-bg);
  }
  figcaption {
    padding: var(--space-5);
    font-size: var(--text-lg);
    font-weight: 500;
    text-align: center;
  }
</style>
