---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Task 4 — Onboarding">
  <section class="card">
    <header>
      <p class="eyebrow">Onboarding</p>
      <h1>Welcome aboard</h1>
      <p class="subtitle">A quick 3-step intro so we can personalise your experience.</p>
    </header>
    <button id="start-btn" type="button">Start onboarding</button>
  </section>

  <script>
    const btn = document.getElementById('start-btn') as HTMLButtonElement | null;
    btn?.addEventListener('click', () => {
      // Reset prior selections at the start of a fresh onboarding.
      sessionStorage.removeItem('t4_gender');
      sessionStorage.removeItem('t4_age');
      sessionStorage.removeItem('t4_name');
      const userId = crypto.randomUUID();
      window.location.assign(`/task-4/${userId}/gender`);
    });
  </script>

  <style>
    .card {
      max-width: 480px;
      margin: 0 auto;
      padding: var(--space-7);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
    }
    .eyebrow {
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-fg-muted);
      margin-bottom: var(--space-2);
    }
    h1 {
      font-size: var(--text-2xl);
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: var(--space-2);
    }
    .subtitle {
      color: var(--color-fg-muted);
      margin-bottom: var(--space-5);
    }
    button {
      padding: var(--space-3) var(--space-5);
      background: var(--color-primary);
      color: var(--color-primary-fg);
      border: 0;
      border-radius: var(--radius-md);
      font-weight: 500;
      font-size: var(--text-base);
      transition: background 120ms ease;
    }
    button:hover { background: var(--color-primary-hover); }
  </style>
</BaseLayout>
